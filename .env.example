# xPay Insider — Environment Variables
# Copy this to .env.local and fill in your values

# Solana payment receiver wallet address (your wallet on devnet)
NEXT_PUBLIC_PAYMENT_RECEIVER=YOUR_SOLANA_WALLET_ADDRESS

# Solana RPC URL (default: devnet)
# NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
